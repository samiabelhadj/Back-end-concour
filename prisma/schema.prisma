

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
   url      = env("DATABASE_URL")
  

}
//leave this one alone
model academic_module {
  id                  Int                   @id @default(autoincrement())
  name                String                @unique(map: "name") @db.VarChar(100)
  description         String?               @db.Text
  created_at          DateTime              @default(dbgenerated("(now())")) @db.DateTime(0)
  // exercise            exercise[]
  // professor_selection professor_selection[]
  role_conflict_log   role_conflict_log[]
  user_module         user_module[]
}
// leave this one
model audit_log {
  id           BigInt   @id @default(autoincrement())
  user_id      Int?
  action       String   @db.VarChar(100)
  target_table String?  @db.VarChar(60)
  target_id    Int?
  description  String?  @db.Text
  ip_address   String?  @db.VarChar(45)
  logged_at    DateTime @default(dbgenerated("(now())")) @db.DateTime(0)
}
/// leave this one 
model role_conflict_log {
  id              Int              @id @default(autoincrement())
  attempted_email String           @db.VarChar(150)
  attempted_role  String           @db.VarChar(255)
  conflict_reason String           @db.VarChar(255)
  competition_id  Int?
  module_id       Int?
  attempted_by    Int
  attempted_at    DateTime         @default(dbgenerated("(now())")) @db.DateTime(0)
  competition     competition?     @relation(fields: [competition_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "role_conflict_log_ibfk_1")
  academic_module academic_module? @relation(fields: [module_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "role_conflict_log_ibfk_2")
  users           users            @relation(fields: [attempted_by], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "role_conflict_log_ibfk_3")

  @@index([attempted_by], map: "attempted_by")
  @@index([competition_id], map: "competition_id")
  @@index([module_id], map: "module_id")
}

//leave this one 
model user_module {
  user_id            Int
  academic_module_id Int
  users              users           @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "user_module_ibfk_1")
  academic_module    academic_module @relation(fields: [academic_module_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "user_module_ibfk_2")

  @@id([user_id, academic_module_id])
  @@index([academic_module_id], map: "academic_module_id")
}

