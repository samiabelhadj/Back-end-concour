model users {
  id                                                            Int                       @id @default(autoincrement())
  first_name                                                    String                    @db.VarChar(80)
  last_name                                                     String                    @db.VarChar(80)
  email                                                         String                    @unique(map: "email") @db.VarChar(150)
  password_hash                                                 String                    @db.VarChar(255)
  grade                                                         users_grade?
  is_active                                                     Boolean                   @default(false)
  created_at                                                    DateTime                  @default(dbgenerated("(now())")) @db.DateTime(0)
  updated_at                                                    DateTime                  @default(dbgenerated("(now())")) @db.DateTime(0)
  faculty                                                       String?                   @db.VarChar(150)
  // anonymisation_key                                             anonymisation_key[]
  // attendance                                                    attendance[]
   competition                                                   competition[]
  // competition_phase                                             competition_phase[]
  // corrector_assignment_corrector_assignment_corrector_idTousers corrector_assignment[]    @relation("corrector_assignment_corrector_idTousers")
 // corrector_assignment_corrector_assignment_assigned_byTousers  corrector_assignment[]    @relation("corrector_assignment_assigned_byTousers")
 // deliberation                                                  deliberation[]
 // deliberation_remark                                           deliberation_remark[]
  // exam_subject                                                  exam_subject[]
  // exercise                                                      exercise[]
  // exercise_version                                              exercise_version[]
  // grading_discrepancy                                           grading_discrepancy[]
  // professor_selection_professor_selection_professor_idTousers   professor_selection[]     @relation("professor_selection_professor_idTousers")
  // professor_selection_professor_selection_selected_byTousers    professor_selection[]     @relation("professor_selection_selected_byTousers")
  // pv                                                            pv[]
  // pv_signature                                                  pv_signature[]
  // result_publication                                            result_publication[]
  role_conflict_log                                             role_conflict_log[]
  // room_supervisor                                               room_supervisor[]
  // subject_generation_rule                                       subject_generation_rule[]
  user_module                                                   user_module[]
  user_role_user_role_user_idTousers                            user_role[]               @relation("user_role_user_idTousers")
  user_role_user_role_assigned_byTousers                        user_role[]               @relation("user_role_assigned_byTousers")
}

enum user_role_role {
  admin
  professor_creator
  corrector
  supervisor
  jury
  coordinator
}

enum users_grade {
  MCB
  MCA
  professeur
  IT_engineer @map("IT engineer")
}



model competition {
  id                      Int                      @id @default(autoincrement())
  name                    String                   @db.VarChar(150)
  academic_year           String                   @db.VarChar(9)
  description             String?                  @db.Text
  max_admitted            Int                      @default(10)
  waiting_list_size       Int                      @default(5)
  discrepancy_threshold   Decimal                  @default(3.00) @db.Decimal(5, 2)
  created_by              Int
  created_at              DateTime                 @default(dbgenerated("(now())")) @db.DateTime(0)
  // anonymised_copy         anonymised_copy[]
  // candidate               candidate[]
  users                   users                    @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "competition_ibfk_1")
  // competition_phase       competition_phase[]
  // deliberation            deliberation?
  // exam_room               exam_room[]
  // exam_subject            exam_subject?
  // exercise                exercise[]
  // professor_selection     professor_selection[]
  // pv                      pv[]
  // ranking                 ranking[]
  // result_publication      result_publication?
   role_conflict_log       role_conflict_log[]
  // subject_generation_rule subject_generation_rule?

  @@index([created_by], map: "created_by")
}


















