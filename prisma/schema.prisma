generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model academicModule {
  id          Int          @id @default(autoincrement())
  name        String       @unique(map: "name") @db.VarChar(100)
  description String?      @db.Text
  created_at  DateTime     @default(dbgenerated("(now())")) @db.DateTime(0)
  userModule  userModule[]
}

model auditLog {
  id           BigInt   @id @default(autoincrement())
  user_id      Int?
  action       String   @db.VarChar(100)
  target_table String?  @db.VarChar(60)
  target_id    Int?
  description  String?  @db.Text
  ip_address   String?  @db.VarChar(45)
  logged_at    DateTime @default(dbgenerated("(now())")) @db.DateTime(0)
}

model userModule {
  user_id           Int
  academicModule_id Int
  users             users          @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "userModule_ibfk_1")
  academicModule    academicModule @relation(fields: [academicModule_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "userModule_ibfk_2")

  @@id([user_id, academicModule_id])
  @@index([academicModule_id], map: "academicModule_id")
}

model userRole {
  id                                 Int             @id @default(autoincrement())
  user_id                            Int
  role                               user_role_role?
  assigned_at                        DateTime        @default(dbgenerated("(now())")) @db.DateTime(0)
  assigned_by                        Int
  users_user_role_user_idTousers     users           @relation("user_role_user_idTousers", fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "user_role_ibfk_1")
  users_user_role_assigned_byTousers users           @relation("user_role_assigned_byTousers", fields: [assigned_by], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "user_role_ibfk_2")

  @@unique([user_id, role], map: "user_role_index_0")
  @@index([assigned_by], map: "assigned_by")
}

model users {
  id                                                          Int                   @id @default(autoincrement())
  first_name                                                  String                @db.VarChar(80)
  last_name                                                   String                @db.VarChar(80)
  email                                                       String                @unique(map: "email") @db.VarChar(150)
  password_hash                                               String                @db.VarChar(255)
  grade                                                       users_grade?
  is_active                                                   Boolean               @default(false)
  created_at                                                  DateTime              @default(dbgenerated("(now())")) @db.DateTime(0)
  updated_at                                                  DateTime              @default(dbgenerated("(now())")) @db.DateTime(0)
  faculty                                                     String?               @db.VarChar(150)
  marked_attendance                                           attendance[]
  created_competitions                                        competition[]
  correctorAssignment_correctorAssignment_assigned_byTousers  correctorAssignment[] @relation("correctorAssignment_assigned_byTousers")
  correctorAssignment_correctorAssignment_corrector_idTousers correctorAssignment[] @relation("correctorAssignment_corrector_idTousers")
  discrepancyAlert                                            discrepancyAlert[]
  exercise                                                    exercise[]
  exerciseComment                                             exerciseComment[]
  generatedSubject                                            generatedSubject[]
  professorSelection_professorSelection_professor_idTousers   professorSelection[]  @relation("professorSelection_professor_idTousers")
  professorSelection_professorSelection_selected_byTousers    professorSelection[]  @relation("professorSelection_selected_byTousers")
  room_supervisions                                           roomSupervisor[]
  userModule                                                  userModule[]
  user_role_user_role_user_idTousers                          userRole[]            @relation("user_role_user_idTousers")
  user_role_user_role_assigned_byTousers                      userRole[]            @relation("user_role_assigned_byTousers")
}

model importLogs {
  id          Int      @id @default(autoincrement())
  filename    String   @db.VarChar(255)
  total_lines Int
  imported    Int
  errors      Int
  imported_by Int
  created_at  DateTime @default(now())
}

model competition {
  id                    Int                  @id @default(autoincrement())
  name                  String               @db.VarChar(200)
  academic_year         String               @db.VarChar(20)
  description           String?              @db.Text
  max_admitted          Int?
  waiting_list_size     Int?
  discrepancy_threshold Decimal?             @db.Decimal(5, 2)
  affectation           Affectation          @default(MANUEL)
  created_by            Int
  created_at            DateTime             @default(now())
  specialty             String?              @db.VarChar(150)
  status                competition_status   @default(ACTIVE)
  target_date           DateTime?
  candidates            candidates[]
  creator               users                @relation(fields: [created_by], references: [id])
  competitionRooms      competitionRoom[]
  discrepancyAlert      discrepancyAlert[]
  exams                 exam[]
  examSession           examSession[]
  exercise              exercise[]
  generatedSubject      generatedSubject[]
  professorSelection    professorSelection[]

  @@index([created_by], map: "competition_created_by_fkey")
}

model candidates {
  id                          Int                 @id @default(autoincrement())
  candidate_id                String?             @unique @db.VarChar(20)
  competition_id              Int
  annee_bac                   String?
  matricule_bac               String?
  nom                         String              @db.VarChar(80)
  prenom                      String              @db.VarChar(80)
  nom_ar                      String?             @db.VarChar(80)
  prenom_ar                   String?             @db.VarChar(80)
  date_naissance              DateTime?
  lieu_naissance              String?             @db.VarChar(100)
  telephone                   String?             @db.VarChar(20)
  email                       String              @unique @db.VarChar(150)
  adresse                     String?             @db.VarChar(255)
  etablissement               String?             @db.VarChar(200)
  annee_diplome               Int?
  type_cursus                 String?             @db.VarChar(30)
  filiere                     String?             @db.VarChar(150)
  specialite                  String?             @db.VarChar(150)
  diplome                     String?             @db.VarChar(100)
  categorie_classement_master String?             @db.VarChar(100)
  moyenne_avant_derniere_ann  Float?
  moyenne_derniere_annee      Float?
  note_memoire_master         Float?
  specialite_demandee_fr      String?             @db.VarChar(200)
  specialite_demandee_ar      String?             @db.VarChar(200)
  url_progres                 String?             @db.VarChar(255)
  sheet_origine               String              @default("LMD") @db.VarChar(20)
  statut                      String              @default("INSCRIT") @db.VarChar(20)
  created_at                  DateTime            @default(now())
  updated_at                  DateTime?           @updatedAt
  examRoomId                  Int?
  anonymisations              anonymisation[]
  attendance                  attendance[]
  candidateRooms              candidateRoom[]
  identity                    candidate_identity?
  competition                 competition         @relation(fields: [competition_id], references: [id])
  examRoom                    examRoom?           @relation(fields: [examRoomId], references: [id])

  @@index([competition_id], map: "candidates_competition_id_fkey")
  @@index([examRoomId], map: "candidates_examRoomId_fkey")
}

model roomSupervisor {
  room_id       Int
  supervisor_id Int
  exam_id       Int
  exam          exam     @relation(fields: [exam_id], references: [id])
  room          examRoom @relation(fields: [room_id], references: [id])
  supervisor    users    @relation(fields: [supervisor_id], references: [id])

  @@id([room_id, supervisor_id, exam_id])
  @@index([exam_id], map: "roomSupervisor_exam_id_fkey")
  @@index([supervisor_id], map: "roomSupervisor_supervisor_id_fkey")
}

model examSession {
  id             Int             @id @default(autoincrement())
  exam_id        Int
  name           String          @db.VarChar(100)
  start_time     DateTime
  end_time       DateTime
  competition_id Int?
  anonymisations anonymisation[]
  attendance     attendance[]
  candidateRooms candidateRoom[]
  competition    competition?    @relation(fields: [competition_id], references: [id])
  exam           exam            @relation(fields: [exam_id], references: [id])

  @@unique([exam_id, name])
  @@index([competition_id], map: "examSession_competition_id_fkey")
}

model attendance {
  id            Int         @id @default(autoincrement())
  candidate_id  Int
  supervisor_id Int
  session_id    Int
  room_id       Int?
  is_present    Boolean     @default(false)
  remarks       String?
  recorded_at   DateTime    @default(now())
  candidate     candidates  @relation(fields: [candidate_id], references: [id])
  room          examRoom?   @relation(fields: [room_id], references: [id])
  session       examSession @relation(fields: [session_id], references: [id])
  supervisor    users       @relation(fields: [supervisor_id], references: [id])

  @@unique([candidate_id, session_id])
  @@index([room_id], map: "attendance_room_id_fkey")
  @@index([session_id], map: "attendance_session_id_fkey")
  @@index([supervisor_id], map: "attendance_supervisor_id_fkey")
}

model examRoom {
  id               Int               @id @default(autoincrement())
  name             String            @db.VarChar(100)
  capacity         Int
  block            String?           @db.VarChar(100)
  status           ExamRoomStatus    @default(AVAILABLE)
  created_at       DateTime          @default(now())
  attendance       attendance[]
  candidateRooms   candidateRoom[]
  candidates       candidates[]
  competitionRooms competitionRoom[]
  equipments       equipments[]
  roomSupervisor   roomSupervisor[]
}

model equipments {
  id          Int      @id @default(autoincrement())
  room_id     Int
  name        String   @db.VarChar(100)
  description String?  @db.Text
  created_at  DateTime @default(dbgenerated("(now())")) @db.DateTime(0)
  room        examRoom @relation(fields: [room_id], references: [id])

  @@index([room_id], map: "equipments_room_id_fkey")
}

model candidateRoom {
  candidate_id Int
  room_id      Int
  exam_id      Int
  session_id   Int?
  place_number Int?
  candidate    candidates   @relation(fields: [candidate_id], references: [id])
  exam         exam         @relation(fields: [exam_id], references: [id])
  room         examRoom     @relation(fields: [room_id], references: [id])
  session      examSession? @relation(fields: [session_id], references: [id])

  @@id([candidate_id, room_id, exam_id])
  @@index([exam_id], map: "candidateRoom_exam_id_fkey")
  @@index([room_id], map: "candidateRoom_room_id_fkey")
  @@index([session_id], map: "candidateRoom_session_id_fkey")
}

model competitionRoom {
  competition_id  Int
  room_id         Int
  places_occupied Int         @default(0)
  competition     competition @relation(fields: [competition_id], references: [id])
  examRoom        examRoom    @relation(fields: [room_id], references: [id])

  @@id([competition_id, room_id])
  @@index([room_id], map: "competitionRoom_room_id_fkey")
}

model exam {
  id              Int              @id @default(autoincrement())
  competition_id  Int
  name            String           @db.VarChar(200)
  description     String?          @db.Text
  coefficient     Float?
  duration        Int?
  created_at      DateTime         @default(now())
  candidateRooms  candidateRoom[]
  competition     competition      @relation(fields: [competition_id], references: [id])
  examSessions    examSession[]
  roomSupervisors roomSupervisor[]

  @@index([competition_id], map: "exam_competition_id_fkey")
}

model exercise {
  id                 Int                 @id @default(autoincrement())
  exercise_code      String              @unique @db.VarChar(20)
  competition_id     Int
  professor_id       Int
  selection_id       Int?
  title              String              @db.VarChar(200)
  subject            String?             @db.VarChar(150)
  points             Float
  nb_questions       Int?
  duration_minutes   Int?
  difficulty         exercise_difficulty @default(MOYEN)
  description        String?             @db.LongText
  file_path          String?             @db.VarChar(255)
  status             exercise_status     @default(BROUILLON)
  submitted_at       DateTime?
  created_at         DateTime            @default(now())
  updated_at         DateTime
  competition        competition         @relation(fields: [competition_id], references: [id])
  users              users               @relation(fields: [professor_id], references: [id])
  professorSelection professorSelection? @relation(fields: [selection_id], references: [id])
  exerciseComment    exerciseComment?
  subjectExercise    subjectExercise[]

  @@index([competition_id])
  @@index([professor_id])
  @@index([selection_id])
}

model exerciseComment {
  id             Int      @id @default(autoincrement())
  exercise_id    Int      @unique
  coordinator_id Int
  comment        String   @db.Text
  created_at     DateTime @default(now())
  updated_at     DateTime
  users          users    @relation(fields: [coordinator_id], references: [id])
  exercise       exercise @relation(fields: [exercise_id], references: [id])

  @@index([coordinator_id])
}

model generatedSubject {
  id              Int                     @id @default(autoincrement())
  competition_id  Int
  index           Int
  total_points    Float
  pdf_path        String?                 @db.VarChar(255)
  status          generatedSubject_status @default(DRAFT)
  generated_at    DateTime                @default(now())
  validated_by    Int?
  validated_at    DateTime?
  competition     competition             @relation(fields: [competition_id], references: [id])
  users           users?                  @relation(fields: [validated_by], references: [id])
  subjectExercise subjectExercise[]

  @@unique([competition_id, index])
  @@index([competition_id])
  @@index([validated_by], map: "generatedSubject_validated_by_fkey")
}

model professorSelection {
  id                                           Int         @id @default(autoincrement())
  competition_id                               Int
  professor_id                                 Int
  selected_by                                  Int
  deadline                                     DateTime
  selected_at                                  DateTime    @default(now())
  exercise                                     exercise[]
  competition                                  competition @relation(fields: [competition_id], references: [id])
  users_professorSelection_professor_idTousers users       @relation("professorSelection_professor_idTousers", fields: [professor_id], references: [id])
  users_professorSelection_selected_byTousers  users       @relation("professorSelection_selected_byTousers", fields: [selected_by], references: [id])

  @@unique([competition_id, professor_id])
  @@index([competition_id])
  @@index([professor_id])
  @@index([selected_by])
}

model subjectExercise {
  subject_id       Int
  exercise_id      Int
  order_index      Int
  exercise         exercise         @relation(fields: [exercise_id], references: [id])
  generatedSubject generatedSubject @relation(fields: [subject_id], references: [id])

  @@id([subject_id, exercise_id])
  @@index([exercise_id])
}

model candidate_identity {
  id            Int        @id @default(autoincrement())
  candidate_id  Int        @unique
  nom_enc       String     @db.Text
  prenom_enc    String     @db.Text
  email_enc     String?    @db.Text
  telephone_enc String?    @db.Text
  cin_enc       String?    @db.Text
  encrypted_at  DateTime   @default(now())
  candidate     candidates @relation(fields: [candidate_id], references: [id])
}

model anonymisation {
  id                  Int                   @id @default(autoincrement())
  candidate_id        Int
  session_id          Int
  anonym_code         String                @unique @db.VarChar(36)
  corr_code           String                @unique @db.VarChar(36)
  created_at          DateTime              @default(now())
  grade               anon_grade?
  candidate           candidates            @relation(fields: [candidate_id], references: [id])
  session             examSession           @relation(fields: [session_id], references: [id])
  correctorAssignment correctorAssignment[]
  discrepancyAlert    discrepancyAlert?

  @@index([candidate_id])
  @@index([session_id])
}

model anon_grade {
  id             Int               @id @default(autoincrement())
  corr_code      String            @unique @db.VarChar(36)
  created_at     DateTime          @default(now())
  corrected_1_at DateTime?
  corrected_2_at DateTime?
  corrected_3_at DateTime?
  corrector_1_id Int?
  corrector_2_id Int?
  corrector_3_id Int?
  final_grade    Float?
  grade_1        Float?
  grade_2        Float?
  grade_3        Float?
  status         anon_grade_status @default(PENDING)
  anonymisation  anonymisation     @relation(fields: [corr_code], references: [corr_code])
}

model correctorAssignment {
  id                                            Int           @id @default(autoincrement())
  corr_code                                     String
  corrector_id                                  Int
  round                                         Int
  assigned_at                                   DateTime      @default(now())
  assigned_by                                   Int?
  users_correctorAssignment_assigned_byTousers  users?        @relation("correctorAssignment_assigned_byTousers", fields: [assigned_by], references: [id])
  anonymisation                                 anonymisation @relation(fields: [corr_code], references: [corr_code])
  users_correctorAssignment_corrector_idTousers users         @relation("correctorAssignment_corrector_idTousers", fields: [corrector_id], references: [id])

  @@unique([corr_code, round])
  @@index([assigned_by], map: "correctorAssignment_assigned_by_fkey")
  @@index([corrector_id])
}

model discrepancyAlert {
  id               Int                          @id @default(autoincrement())
  corr_code        String                       @unique
  competition_id   Int
  corrector1_grade Float
  corrector2_grade Float
  discrepancy      Float
  status           discrepancyAlert_status      @default(PENDING)
  resolution       discrepancyAlert_resolution?
  resolved_by      Int?
  resolved_at      DateTime?
  created_at       DateTime                     @default(now())
  competition      competition                  @relation(fields: [competition_id], references: [id])
  anonymisation    anonymisation                @relation(fields: [corr_code], references: [corr_code])
  users            users?                       @relation(fields: [resolved_by], references: [id])

  @@index([competition_id], map: "discrepancyAlert_competition_id_fkey")
  @@index([resolved_by], map: "discrepancyAlert_resolved_by_fkey")
}

enum anon_grade_status {
  PENDING
  FIRST_DONE
  SECOND_DONE
  THIRD_REQUIRED
  COMPLETED
}

enum user_role_role {
  admin
  professor_creator
  corrector
  supervisor
  jury
  coordinator
  anonymat
}

enum users_grade {
  MCB
  MCA
  professeur
  IT_engineer @map("IT engineer")
}

enum Affectation {
  MANUEL
  AUTOMATIQUE
}

enum ExamRoomStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  OUT_OF_SERVICE
  CLOSED
}

enum competition_status {
  ACTIVE
  FINISHED
}

enum generatedSubject_status {
  DRAFT
  OFFICIAL
  REJECTED
}

enum exercise_difficulty {
  FACILE
  MOYEN
  DIFFICILE
}

enum exercise_status {
  BROUILLON
  SOUMIS
  EN_REVISION
  VALIDE
}

enum discrepancyAlert_status {
  PENDING
  RESOLVED
}

enum discrepancyAlert_resolution {
  MANUAL
  AUTO
}
